{
  "name": "TipAi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "TipAi Desktop - 本地AI提示词工程工具",
  "author": "TipAi Team",
  "main": "electron/main.cjs",
  "homepage": ".",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && electron .",
    "build": "vite build && esbuild api/boot.ts --platform=node --bundle --format=esm --outdir=dist --external:sharp --banner:js=\"import { createRequire as __createRequire } from 'module';import { fileURLToPath } from 'node:url';import nodePath from 'node:path';const require=__createRequire(import.meta.url);const __filename=fileURLToPath(import.meta.url);const __dirname=nodePath.dirname(__filename);\"",
    "build:electron": "npm run build",
    "build:desktop": "npm run build:electron && electron-builder",
    "native:build": "cd native && npm run build",
    "native:build:debug": "cd native && npm run build:debug",
    "build:desktop:win": "npm run native:build && npm run build && electron-builder --win",
    "build:desktop:mac": "npm run native:build && npm run build:electron && electron-builder --mac",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report e2e-results/html-report",
    "db:seed": "tsx db/seed.ts",
    "db:backup": "tsx db/backup.ts backup",
    "db:export-json": "tsx db/backup.ts export-json",
    "db:export-sql": "tsx db/backup.ts export-sql"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.16",
    "@trpc/client": "^11.8.1",
    "@trpc/react-query": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.5.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "hono": "^4.8.3",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.6",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^17.0.6",
    "react-resizable-panels": "^4.2.2",
    "react-router": "^7.6.1",
    "simplex-noise": "4.0.3",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.1",
    "@hono/vite-dev-server": "^0.25.3",
    "@napi-rs/cli": "^3.6.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "kimi-plugin-inspect-react": "^1.0.3",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.12",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "esbuild": "^0.27.2"
  },
  "build": {
    "appId": "com.tipai.desktop",
    "productName": "TipAi",
    "copyright": "Copyright © 2026 TipAi",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/*.node",
      "native/index.js",
      "native/package.json"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "native/*.node",
      "native/index.js",
      "native/package.json",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "db/migrations",
        "to": "db/migrations"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "aitippro",
      "repo": "TipAi",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
