# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git

# Application
NODE_ENV=development
APP_URL=https://your-production-url.com
APP_ID=your_app_id_here
APP_SECRET=your_app_secret_here

# Database (SQLite)
# Desktop app: 自动使用用户数据目录 ~/.config/TipAi/data.db
# 如需自定义路径，取消下面注释并设置路径：
# DATABASE_URL=file:./data.db

# Kimi API
KIMI_AUTH_URL=https://kimi-auth.example.com
KIMI_OPEN_URL=https://kimi-open.example.com

# Owner
OWNER_UNION_ID=your_union_id_here

# AI Model API Keys (可选)
# KIMI_API_KEY=your_kimi_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
# OPENAI_API_KEY=your_openai_api_key
# GEMINI_API_KEY=your_gemini_api_key

# Cloud Sync (预留)
# CLOUD_SYNC_URL=https://your-cloud-sync-url.com

# Ollama (本地模型)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
