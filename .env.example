# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git

# Application
NODE_ENV=development
APP_URL=https://your-production-url.com
APP_ID=your_app_id_here
APP_SECRET=your_app_secret_here

# Database
DATABASE_URL=mysql://user:password@host:3306/database_name

# Kimi API
KIMI_AUTH_URL=https://kimi-auth.example.com
KIMI_OPEN_URL=https://kimi-open.example.com

# Owner
OWNER_UNION_ID=your_union_id_here

# API Key Encryption (required in production)
API_KEY_SECRET=your_api_key_encryption_secret_here
